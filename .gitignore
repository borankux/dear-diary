# Local diary data and generated reading artifacts.
# The normal location is ~/Documents/dear-diary/, outside this repo. These
# rules prevent accidental commits if DIARY_DIR is pointed at the checkout or
# the generated files are copied here.
/[0-9][0-9][0-9][0-9]-[0-9][0-9]/
/dear-diary/
/process/
/entries/
/dashboard.html
